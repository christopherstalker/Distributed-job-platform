WORKER_HEARTBEAT_EVERY=5s
DEFAULT_DEDUPE_WINDOW=15m
POLICY_REFRESH_INTERVAL=5s
WORKER_QUEUES=critical,default,low
WORKER_CONCURRENCY=32
